:80 {
    root * /usr/share/caddy
    encode gzip

    # API, WebSocket en tiempo real y archivos subidos -> backend (wtxapi)
    handle /api/* {
        reverse_proxy wtxapi:3000
    }

    handle /ws {
        reverse_proxy wtxapi:3000
    }

    handle /uploads/* {
        reverse_proxy wtxapi:3000
    }

    handle {
        try_files {path} {path}/ /index.html
        file_server
    }
}
