# ==================== WTX — Variables de entorno ====================
# Copia a .env y rellena. NUNCA commitees .env con valores reales.

# ── Base de datos PostgreSQL ──
POSTGRES_USER=whatsapp
POSTGRES_PASSWORD=          # requerido — genera: openssl rand -hex 16
POSTGRES_DB=whatsapp_agent

# ── OpenAI ──
OPENAI_API_KEY=sk-xxxx      # requerido

# ── Secretos ──
SECRET_KEY=                 # requerido — JWT. genera: openssl rand -hex 32
WEBHOOK_TOKEN=              # requerido — auth del webhook API<->bridge. openssl rand -hex 32

# ── WhatsApp (bridge local o WAHA/Evolution) ──
WHATSAPP_API_URL=http://whatsapp-bridge:3080
WHATSAPP_API_KEY=          # requerido — API key del bridge/WAHA

# ── CORS (solo prod) ──
# Lista separada por comas. NUNCA uses "*" (inválido con credenciales).
CORS_ORIGINS=https://app.tudominio.com

# ── Producción (Coolify) ──
# En prod el compose usa DB_PASSWORD en lugar de POSTGRES_PASSWORD:
# DB_PASSWORD=
# FRONTEND_DOMAIN=app.tudominio.com
